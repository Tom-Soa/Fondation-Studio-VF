# ── Resend (formulaire de contact) ─────────────────────────────
# 1. Crée un compte sur https://resend.com
# 2. Génère une clé API : https://resend.com/api-keys
# 3. Pour la production : vérifie ton domaine d'envoi
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adresse qui reçoit les demandes du formulaire
CONTACT_EMAIL=contact@fondationstudio.fr

# Adresse d'expédition (doit être sur un domaine vérifié dans Resend).
# En dev sans domaine vérifié, utilise : "Fondation Studio <onboarding@resend.dev>"
FROM_EMAIL=Fondation Studio <contact@fondationstudio.fr>
